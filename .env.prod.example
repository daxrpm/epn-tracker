# Docker Compose - plantilla de producción. No guardes secretos reales en Git.
APP_ENV=production
DEBUG=false

POSTGRES_USER=epn_app
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=epn

JWT_SECRET=CHANGE_ME_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
BACKEND_CORS_ORIGINS=https://app.example.com

EMAIL_BACKEND=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USERNAME
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10

FIRST_SUPERADMIN_EMAIL=admin@epn.edu.ec
FIRST_SUPERADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
