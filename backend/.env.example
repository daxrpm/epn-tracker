# App
APP_ENV=dev
APP_NAME=EPN Notas Mallas
DEBUG=true

# Database (async SQLAlchemy + asyncpg)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=epn
POSTGRES_PASSWORD=epn
POSTGRES_DB=epn
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# CORS (comma-separated frontend origins)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (cache, rate limit, códigos de verificación)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Registro EPN
ALLOWED_EMAIL_DOMAIN=epn.edu.ec
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODES_PER_HOUR=5

# Correo local: el código aparece en los logs del backend.
EMAIL_BACKEND=console

# Correo en deploy: EMAIL_BACKEND=smtp y configura estas variables.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=apikey-or-user
# SMTP_PASSWORD=replace-me
# SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=10

# Bootstrap del primer super admin (para python -m seeds.create_admin)
FIRST_SUPERADMIN_EMAIL=admin@epn.edu.ec
FIRST_SUPERADMIN_PASSWORD=ChangeMe-12345
