# App
APP_ENV=dev
APP_NAME=EPN Notas Mallas
DEBUG=true

# Database (async SQLAlchemy + asyncpg)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=epn
POSTGRES_PASSWORD=epn
POSTGRES_DB=epn

# Redis (cache, rate limit, códigos de verificación)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Registro EPN
ALLOWED_EMAIL_DOMAIN=epn.edu.ec
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODES_PER_HOUR=5

# Correo (dev = consola)
EMAIL_BACKEND=console
